{% comment %}
  SIGNAR Hero Section
  - Full-width, high-res background image
  - Elegant typography with fade-in animations
  - 'Shop Now' button with luxury hover animation
{% endcomment %}

<section class="signar-hero" 
         style="background-image: url('{{ section.settings.hero_image | image_url: width: 1920 }}'); min-height: {{ section.settings.hero_height }}vh;"
         data-section-id="{{ section.id }}">
  
  <div class="signar-hero__overlay" style="background-color: rgba(0,0,0,{{ section.settings.overlay_opacity | divided_by: 100.0 }});"></div>

  <div class="signar-hero__content">
    {% if section.settings.subtitle != blank %}
      <p class="signar-hero__subtitle reveal-text">{{ section.settings.subtitle }}</p>
    {% endif %}
    
    {% if section.settings.title != blank %}
      <h1 class="signar-hero__title reveal-text">{{ section.settings.title }}</h1>
    {% endif %}
    
    {% if section.settings.description != blank %}
      <p class="signar-hero__description reveal-text">{{ section.settings.description }}</p>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_link }}" class="signar-hero__btn reveal-text">
        <span class="signar-hero__btn-text">{{ section.settings.button_text }}</span>
        <span class="signar-hero__btn-icon">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"></path>
          </svg>
        </span>
      </a>
    {% endif %}
  </div>

  <style>
    .signar-hero {
      position: relative;
      width: 100%;
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .signar-hero__overlay {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      z-index: 1;
    }

    .signar-hero__content {
      position: relative;
      z-index: 2;
      text-align: center;
      color: var(--color-white);
      padding: 0 var(--spacing-md);
      max-width: 900px;
    }

    .signar-hero__subtitle {
      font-size: 0.85rem;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      margin-bottom: var(--spacing-md);
      color: rgba(255, 255, 255, 0.8);
    }

    .signar-hero__title {
      font-family: var(--font-serif);
      font-size: clamp(3rem, 8vw, 6rem);
      font-weight: 700;
      letter-spacing: 0.15em;
      line-height: 1.1;
      margin-bottom: var(--spacing-md);
    }

    .signar-hero__description {
      font-size: 1.1rem;
      font-weight: 300;
      letter-spacing: 0.1em;
      margin-bottom: var(--spacing-lg);
      color: rgba(255, 255, 255, 0.9);
      max-width: 600px;
      margin-left: auto;
      margin-right: auto;
    }

    .signar-hero__btn {
      display: inline-flex;
      align-items: center;
      gap: 1rem;
      padding: 1.2rem 3rem;
      border: 1px solid var(--color-white);
      color: var(--color-white);
      text-decoration: none;
      font-size: 0.85rem;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      transition: all var(--transition-smooth);
      position: relative;
      overflow: hidden;
      background: transparent;
    }

    .signar-hero__btn::before {
      content: '';
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      background: var(--color-white);
      transform: scaleX(0);
      transform-origin: right;
      transition: transform var(--transition-smooth);
      z-index: -1;
    }

    .signar-hero__btn:hover {
      color: var(--color-black);
      letter-spacing: 0.3em;
    }

    .signar-hero__btn:hover::before {
      transform: scaleX(1);
      transform-origin: left;
    }

    .signar-hero__btn-icon {
      transition: transform var(--transition-smooth);
    }

    .signar-hero__btn:hover .signar-hero__btn-icon {
      transform: translateX(5px);
    }

    /* Reveal Animations */
    .reveal-text {
      opacity: 0;
      transform: translateY(30px);
      animation: revealUp 1s ease forwards;
    }
    .reveal-text:nth-child(1) { animation-delay: 0.3s; }
    .reveal-text:nth-child(2) { animation-delay: 0.6s; }
    .reveal-text:nth-child(3) { animation-delay: 0.9s; }
    .reveal-text:nth-child(4) { animation-delay: 1.2s; }

    @keyframes revealUp {
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @media (max-width: 768px) {
      .signar-hero__btn {
        padding: 1rem 2rem;
        font-size: 0.75rem;
      }
    }
  </style>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "signar-hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Background image",
      "info": "Recommended: 1920x1080px or higher"
    },
    {
      "type": "range",
      "id": "hero_height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Section height",
      "default": 100
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "label": "Overlay darkness",
      "default": 40
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Luxury Fragrances"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "SIGNAR"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Where Elegance Meets Essence"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "/collections/all"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}

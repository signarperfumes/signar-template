{% comment %}
  SIGNAR Footer Section
  - Top row: Newsletter signup
  - Bottom grid: Logo, Discover, Policies, Social
  - Fully editable via Shopify Theme Editor
{% endcomment %}

<section class="signar-footer" data-section-id="{{ section.id }}">
  <!-- Newsletter Row -->
  {% if section.settings.newsletter_enabled %}
    <div class="footer-newsletter">
      <div class="newsletter-content">
        <p class="newsletter-subtitle">{{ section.settings.newsletter_subtitle }}</p>
        <h2 class="newsletter-title">{{ section.settings.newsletter_title }}</h2>
        <p class="newsletter-desc">{{ section.settings.newsletter_description }}</p>
        
        {% form 'customer', class: 'newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" 
                 name="contact[email]" 
                 class="newsletter-input" 
                 placeholder="{{ section.settings.newsletter_placeholder }}"
                 required>
          <button type="submit" class="newsletter-submit">
            {{ section.settings.newsletter_button_text }}
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
          </button>
        {% endform %}
        
        <p class="newsletter-note">{{ section.settings.newsletter_note }}</p>
      </div>
    </div>
  {% endif %}

  <!-- Footer Grid -->
  <footer class="footer-main">
    <div class="footer-content">
      <!-- Column 1: Logo & Description -->
      <div class="footer-brand">
        <div class="footer-logo">
          {% if section.settings.footer_logo != blank %}
            <img src="{{ section.settings.footer_logo | image_url: width: 200 }}" 
                 alt="{{ shop.name }}" 
                 width="{{ section.settings.footer_logo_width }}">
          {% else %}
            <span>{{ shop.name | upcase }}</span>
          {% endif %}
        </div>
        <p class="footer-description">{{ section.settings.footer_description }}</p>
        
        {% if section.settings.social_enabled %}
          <div class="footer-social">
            {% if section.settings.social_instagram != blank %}
              <a href="{{ section.settings.social_instagram }}" 
                 class="social-link" 
                 aria-label="Instagram"
                 target="_blank"
                 rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="2" y="2" width="20" height="20" rx="5"></rect>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
                </svg>
              </a>
            {% endif %}
            
            {% if section.settings.social_facebook != blank %}
              <a href="{{ section.settings.social_facebook }}" 
                 class="social-link" 
                 aria-label="Facebook"
                 target="_blank"
                 rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
                </svg>
              </a>
            {% endif %}
            
            {% if section.settings.social_twitter != blank %}
              <a href="{{ section.settings.social_twitter }}" 
                 class="social-link" 
                 aria-label="Twitter"
                 target="_blank"
                 rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path>
                </svg>
              </a>
            {% endif %}
            
            {% if section.settings.social_youtube != blank %}
              <a href="{{ section.settings.social_youtube }}" 
                 class="social-link" 
                 aria-label="YouTube"
                 target="_blank"
                 rel="noopener">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path>
                  <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
                </svg>
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <!-- Column 2: Discover -->
      <div class="footer-column">
        <h4 class="footer-heading">{{ section.settings.discover_heading }}</h4>
        <ul class="footer-links">
          {% for link in section.settings.discover_menu.links %}
            <li><a href="{{ link.url }}" class="footer-link">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <!-- Column 3: Policies -->
      <div class="footer-column">
        <h4 class="footer-heading">{{ section.settings.policies_heading }}</h4>
        <ul class="footer-links">
          {% if shop.shipping_policy %}
            <li><a href="{{ shop.shipping_policy.url }}" class="footer-link">{{ section.settings.shipping_label }}</a></li>
          {% endif %}
          {% if shop.refund_policy %}
            <li><a href="{{ shop.refund_policy.url }}" class="footer-link">{{ section.settings.returns_label }}</a></li>
          {% endif %}
          {% if shop.privacy_policy %}
            <li><a href="{{ shop.privacy_policy.url }}" class="footer-link">{{ section.settings.privacy_label }}</a></li>
          {% endif %}
          {% if shop.terms_of_service %}
            <li><a href="{{ shop.terms_of_service.url }}" class="footer-link">{{ section.settings.terms_label }}</a></li>
          {% endif %}
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div class="footer-column">
        <h4 class="footer-heading">{{ section.settings.contact_heading }}</h4>
        <ul class="footer-links">
          {% if section.settings.contact_email != blank %}
            <li><a href="mailto:{{ section.settings.contact_email }}" class="footer-link">{{ section.settings.contact_email }}</a></li>
          {% endif %}
          {% if section.settings.contact_phone != blank %}
            <li><a href="tel:{{ section.settings.contact_phone }}" class="footer-link">{{ section.settings.contact_phone }}</a></li>
          {% endif %}
          {% if section.settings.contact_address != blank %}
            <li><span class="footer-text">{{ section.settings.contact_address }}</span></li>
          {% endif %}
        </ul>
      </div>
    </div>

    <!-- Footer Bottom -->
    <div class="footer-bottom">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.footer_bottom_text }}</p>
    </div>
  </footer>

  <style>
    /* ============================================
       SIGNAR Footer Styles
       ============================================ */
    .signar-footer {
      background: var(--color-black);
      color: var(--color-white);
    }

    /* Newsletter Section */
    .footer-newsletter {
      padding: 6rem 4rem;
      text-align: center;
      border-bottom: 1px solid #222;
    }

    .newsletter-content {
      max-width: 700px;
      margin: 0 auto;
    }

    .newsletter-subtitle {
      font-size: 0.85rem;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--color-muted);
      margin-bottom: 1rem;
    }

    .newsletter-title {
      font-family: var(--font-serif);
      font-size: 3rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      margin-bottom: 1.5rem;
    }

    .newsletter-desc {
      font-size: 1rem;
      color: #bbb;
      line-height: 1.8;
      margin-bottom: 3rem;
      letter-spacing: 0.02em;
    }

    .newsletter-form {
      display: flex;
      gap: 0;
      max-width: 500px;
      margin: 0 auto 1.5rem;
      border-bottom: 1px solid #444;
    }

    .newsletter-input {
      flex: 1;
      padding: 1.2rem 0;
      background: transparent;
      border: none;
      color: var(--color-white);
      font-family: var(--font-sans);
      font-size: 0.95rem;
      letter-spacing: 0.05em;
      outline: none;
    }

    .newsletter-input::placeholder {
      color: #777;
    }

    .newsletter-submit {
      padding: 1.2rem 2rem;
      background: transparent;
      border: none;
      color: var(--color-white);
      font-family: var(--font-sans);
      font-size: 0.85rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .newsletter-submit:hover {
      color: #ccc;
      letter-spacing: 0.25em;
    }

    .newsletter-submit svg {
      transition: transform 0.3s ease;
    }

    .newsletter-submit:hover svg {
      transform: translateX(5px);
    }

    .newsletter-note {
      font-size: 0.75rem;
      color: #777;
      letter-spacing: 0.1em;
    }

    /* Footer Main */
    .footer-main {
      padding: 6rem 4rem 3rem;
    }

    .footer-content {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 4rem;
      max-width: 1400px;
      margin: 0 auto 4rem;
    }

    .footer-brand {
      max-width: 300px;
    }

    .footer-logo {
      font-family: var(--font-serif);
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: 0.3em;
      margin-bottom: 1.5rem;
    }

    .footer-logo img {
      max-height: 40px;
      width: auto;
    }

    .footer-description {
      font-size: 0.9rem;
      line-height: 1.8;
      color: #999;
      letter-spacing: 0.02em;
      margin-bottom: 1.5rem;
    }

    .footer-social {
      display: flex;
      gap: 1rem;
    }

    .social-link {
      width: 40px;
      height: 40px;
      border: 1px solid #333;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #999;
      transition: all 0.3s ease;
    }

    .social-link:hover {
      background: var(--color-white);
      color: var(--color-black);
      border-color: var(--color-white);
    }

    .footer-column h4 {
      font-family: var(--font-serif);
      font-size: 1.1rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
      letter-spacing: 0.1em;
    }

    .footer-links {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .footer-links li {
      margin-bottom: 0.8rem;
    }

    .footer-link {
      color: #999;
      text-decoration: none;
      font-size: 0.9rem;
      letter-spacing: 0.05em;
      transition: color 0.3s ease;
    }

    .footer-link:hover {
      color: var(--color-white);
    }

    .footer-text {
      color: #999;
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .footer-bottom {
      border-top: 1px solid #333;
      padding-top: 2rem;
      text-align: center;
      color: #666;
      font-size: 0.85rem;
      letter-spacing: 0.05em;
    }

    /* Responsive */
    @media (max-width: 1024px) {
      .footer-newsletter {
        padding: 4rem 2rem;
      }

      .footer-main {
        padding: 4rem 2rem 2rem;
      }

      .footer-content {
        grid-template-columns: 1fr 1fr;
        gap: 2.5rem;
      }

      .newsletter-title {
        font-size: 2.2rem;
      }
    }

    @media (max-width: 768px) {
      .footer-newsletter {
        padding: 3rem 1.2rem;
      }

      .footer-main {
        padding: 3rem 1.2rem 2rem;
        text-align: center;
      }

      .footer-content {
        grid-template-columns: 1fr;
        gap: 2rem;
        justify-items: center;
      }

      .footer-brand {
        max-width: 100%;
        text-align: center;
      }

      .footer-logo {
        font-size: 1.5rem;
        margin-bottom: 1rem;
      }

      .footer-description {
        font-size: 0.85rem;
      }

      .footer-social {
        justify-content: center;
      }

      .footer-column {
        text-align: center;
      }

      .footer-column h4 {
        margin-bottom: 1rem;
      }

      .newsletter-title {
        font-size: 1.8rem;
      }

      .newsletter-desc {
        font-size: 0.9rem;
      }

      .newsletter-form {
        flex-direction: column;
        border-bottom: none;
        gap: 1rem;
      }

      .newsletter-input {
        border-bottom: 1px solid #444;
        padding: 1rem 0;
      }

      .newsletter-submit {
        justify-content: center;
        padding: 1rem;
        border: 1px solid #444;
      }
    }
  </style>
</section>

{% schema %}
{
  "name": "Footer",
  "tag": "section",
  "class": "signar-footer-section",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Newsletter Settings"
    },
    {
      "type": "checkbox",
      "id": "newsletter_enabled",
      "label": "Enable newsletter section",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_subtitle",
      "label": "Newsletter subtitle",
      "default": "Join The SIGNAR Circle"
    },
    {
      "type": "text",
      "id": "newsletter_title",
      "label": "Newsletter title",
      "default": "Stay In The Know"
    },
    {
      "type": "textarea",
      "id": "newsletter_description",
      "label": "Newsletter description",
      "default": "Subscribe to receive exclusive access to new launches, private events, and members-only offers. Be the first to experience the art of SIGNAR."
    },
    {
      "type": "text",
      "id": "newsletter_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "newsletter_button_text",
      "label": "Button text",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "newsletter_note",
      "label": "Privacy note",
      "default": "By subscribing, you agree to our Privacy Policy. Unsubscribe anytime."
    },
    {
      "type": "header",
      "content": "Footer Logo"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer logo image"
    },
    {
      "type": "range",
      "id": "footer_logo_width",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo width",
      "default": 150
    },
    {
      "type": "textarea",
      "id": "footer_description",
      "label": "Footer description",
      "default": "Crafting luxury fragrances that embody sophistication and elegance. Each scent tells a story of refinement and timeless beauty."
    },
    {
      "type": "header",
      "content": "Social Media"
    },
    {
      "type": "checkbox",
      "id": "social_enabled",
      "label": "Enable social links",
      "default": true
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter URL"
    },
    {
      "type": "url",
      "id": "social_youtube",
      "label": "YouTube URL"
    },
    {
      "type": "header",
      "content": "Discover Column"
    },
    {
      "type": "text",
      "id": "discover_heading",
      "label": "Heading",
      "default": "Discover"
    },
    {
      "type": "link_list",
      "id": "discover_menu",
      "label": "Menu",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Policies Column"
    },
    {
      "type": "text",
      "id": "policies_heading",
      "label": "Heading",
      "default": "Policies"
    },
    {
      "type": "text",
      "id": "shipping_label",
      "label": "Shipping policy label",
      "default": "Shipping Policy"
    },
    {
      "type": "text",
      "id": "returns_label",
      "label": "Returns policy label",
      "default": "Return Policy"
    },
    {
      "type": "text",
      "id": "privacy_label",
      "label": "Privacy policy label",
      "default": "Privacy Policy"
    },
    {
      "type": "text",
      "id": "terms_label",
      "label": "Terms label",
      "default": "Terms of Service"
    },
    {
      "type": "header",
      "content": "Contact Column"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Heading",
      "default": "Contact"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Phone"
    },
    {
      "type": "textarea",
      "id": "contact_address",
      "label": "Address"
    },
    {
      "type": "header",
      "content": "Footer Bottom"
    },
    {
      "type": "text",
      "id": "footer_bottom_text",
      "label": "Bottom text",
      "default": "All rights reserved. Crafted with elegance in Pakistan."
    }
  ]
}
{% endschema %}
